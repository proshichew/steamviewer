@using Steamviewer.Entities.SteamModels
@using Steamviewer.Entities.ComponentModels
@using System.Globalization
@using Steamviewer.Entities.DTOs
@inject Steamviewer.Components.Shared.Services.Interfaces.IGameService GameService;

<div>
    <div class="game-card @(AdditionalInfo ? "expanded" : "") @(IsHighlighted ? "highlighted" : "")">
        <div class="game-card-main-info">
            <!-- Левая часть: картинка и теги -->
            <button class="close-btn" @onclick="CloseCard">×</button>
            <div class="game-card-left">
                <img src="@Game.HeaderImage" alt="@Game.Name"
                     class="game-card-image"
                     onerror="this.src='https://via.placeholder.com/300x150?text=No+Image'" />

                @if (Game.Tags != null && Game.Tags.Any())
                {
                    <div class="game-card-tags">
                        @foreach (var tag in Game.Tags.Take(5))
                        {
                            <span class="game-tag">@tag</span>
                        }
                    </div>
                }
            </div>

            <!-- Правая часть: инфа об игре -->
            <div class="game-card-right">
                <div>
                    <div class="game-card-title">@Game.Name</div>

                    @if (!string.IsNullOrWhiteSpace(Game.Description))
                    {
                        <div class="game-card-description">@Game.Description</div>
                    }
                    else
                    {
                        <div class="game-card-description">Описание недоступно.</div>
                    }


                    <div class="game-card-meta">
                        <span class="game-card-meta-label">Дата выхода:</span>
                        <span class="game-card-meta-value">@Game.ReleaseDate</span>
                    </div>
                </div>

                @if (Game.Developers != null && Game.Developers.Any())
                {
                    <div class="game-card-meta">
                        <span class="game-card-meta-label">Разработчики:</span>
                        <span class="game-card-meta-dev">
                            @foreach (var dev in Game.Developers.Take(5))
                            {
                                @(dev + " ")
                                ;
                            }
                        </span>
                    </div>
                }

                @if (Game.Publishers != null && Game.Publishers.Any())
                {
                    <div class="game-card-meta">
                        <span class="game-card-meta-label">Издатели:</span>
                        <span class="game-card-meta-pub">
                            @foreach (var pub in Game.Publishers.Take(5))
                            {
                                @(pub + " ")
                                ;
                            }
                        </span>
                    </div>
                }

            </div>
            <div class="game-card-price-box @(Game.FinalPrice == 0 ? "free" : Game.Sale > 0 ? "discounted" : "")">
                @if (Game.FinalPrice == 0)
                {
                    <span>Бесплатно</span>
                }
                else if (Game.Sale > 0)
                {
                    <span class="old-price">@($"{Game.InitialPriceFormatted}")</span>
                    <span class="final-price">@($"{Game.FinalPriceFormatted}")</span>
                    <span class="discount-percent">-@Game.Sale%</span>
                }
                else
                {
                    <span class="final-price">@($"{Game.FinalPriceFormatted}")</span>
                }
            </div>



            <div class="game-card-notify-at">
                @if (isEditingSaleToNotify)
                {
                    <div class="sale-edit-container">
                        <input type="number" @bind="currentSaleToNotify" min="0" max="100" class="sale-input" />
                        <span class="sale-input-suffix">%</span>
                        <div class="sale-edit-buttons">
                            <button @onclick="SaveSaleToNotify" class="sale-button sale-save" title="Сохранить">✓</button>
                            <button @onclick="CancelEditSaleToNotify" class="sale-button sale-cancel" title="Отмена">×</button>
                        </div>
                    </div>
                }
                else
                {
                    <span class="sale-notify-text">Уведомлять при: <strong>@Game.SaleToNotify%</strong></span>
                    <button @onclick="StartEditSaleToNotify" class="sale-edit-button" title="Изменить порог">
                        <svg class="sale-edit-icon" viewBox="0 0 24 24">
                            <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                        </svg>
                    </button>
                }
            </div>


        </div>

        <div class="game-card-additional-info">
            <button @onclick="ShowMore" class="show-more-btn">@(AdditionalInfo ? "Скрыть" : "Показать больше...") </button>
            @if (AdditionalInfo)
            {
                <div class="game-card-screenshots">

                    <ImageCarousel Screenshots=Game.Screenshots />
                </div>

                <div class="game-card-requirements">
                    <h4>Минимальные требования:</h4>

                    @if (Game.Platforms.windows && Game.PcRequirements != null)
                    {
                        <div class="bb_ul">@((MarkupString)Game.PcRequirements.minimum)</div>
                    }
                    else
                    {
                        <span class="platform-tag unavailable">Игры нет на Windows</span>
                    }
                </div>

                <div class="game-card-rating">
                    @if (Game.Metacritic != null)
                    {
                        <div class="metacritic-score">
                            <div class="metacritic-icon" title="Metacritic Score"></div>
                            <div class="metacritic-value @GetMetacriticClass(Game.Metacritic.score)">
                                @Game.Metacritic.score
                            </div>
                            <span>Metacritic Score</span>
                        </div>
                    }

                    <div class="game-card-user-desc">
                        @if (isEditingNote)
                        {
                            <div class="user-note-edit">
                                <textarea @bind="currentUserNote" class="user-note-textarea"></textarea>
                                <div class="user-note-buttons">
                                    <button @onclick="CancelEditNote" class="note-button note-cancel">Отмена</button>
                                    <button @onclick="SaveUserNote" class="note-button note-save">Сохранить</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="user-note-display">
                                @if (!string.IsNullOrEmpty(Game.UserNote))
                                {
                                    <div class="user-note-content">
                                        <span class="user-note-text">@Game.UserNote</span>
                                        <button @onclick="StartEditNote" class="note-edit-button">
                                            <svg class="note-edit-icon" viewBox="0 0 24 24">
                                                <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                                            </svg>
                                            Редактировать
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div class="user-note-content">
                                        <span class="user-note-text">Добавить заметку</span>
                                        <button @onclick="StartEditNote" class="note-edit-button">
                                            <svg class="note-edit-icon" viewBox="0 0 24 24">
                                                <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                                            </svg>
                                            Добавить
                                        </button>
                                    </div>
                                }
                            </div>

                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public GameCardInfo Game { get; set; } = default!;
    [Parameter] public EventCallback OnCardClose { get; set; }

    private bool IsHighlighted => Game.SaleToNotify.HasValue && Game.Sale > Game.SaleToNotify.Value;
    private bool AdditionalInfo = false;

    // Для редактирования заметки
    private bool isEditingNote = false;
    private string currentUserNote = string.Empty;

    // Для редактирования SaleToNotify
    private bool isEditingSaleToNotify = false;
    private int currentSaleToNotify;

    private void ShowMore()
    {
        AdditionalInfo = !AdditionalInfo;
    }

    private async Task CloseCard() => await OnCardClose.InvokeAsync();

    private string GetMetacriticClass(int score)
    {
        return score >= 75 ? "metacritic-positive" :
               score >= 50 ? "metacritic-mixed" : "metacritic-negative";
    }

    // Методы для работы с заметкой
    private void StartEditNote()
    {
        currentUserNote = Game.UserNote ?? string.Empty;
        isEditingNote = true;
    }

    private void CancelEditNote()
    {
        isEditingNote = false;
    }

    // Методы для работы с SaleToNotify
    private void StartEditSaleToNotify()
    {
        currentSaleToNotify = Game.SaleToNotify ?? 0;
        isEditingSaleToNotify = true;
    }

    private void CancelEditSaleToNotify()
    {
        isEditingSaleToNotify = false;
    }

    private async Task SaveSaleToNotify()
    {
        Game.SaleToNotify = currentSaleToNotify;
        isEditingSaleToNotify = false;
        await SaveGameChanges();
        ShowToast($"Уведомление при {currentSaleToNotify}% сохранено");
    }

    private async Task SaveUserNote()
    {
        Game.UserNote = currentUserNote;
        isEditingNote = false;
        await SaveGameChanges();
        ShowToast("Заметка сохранена");
    }

    private async Task SaveGameChanges()
    {
        try
        {
            await GameService.UpdateGameAsync(Game.DbId, new GameDTO(
                Game.DbId,
                Game.SteamId,
                Game.UserNote,
                Game.SaleToNotify.Value));
        }
        catch (Exception ex)
        {
            ShowToast("Ошибка при сохранении изменений");
            Console.WriteLine($"Error saving changes: {ex.Message}");
        }
    }

    private void ShowToast(string message)
    {
        // Реализация показа уведомления (можно использовать существующую в вашем проекте)
        // Например, можно использовать ToastService или StateHasChanged для обновления UI
    }
}
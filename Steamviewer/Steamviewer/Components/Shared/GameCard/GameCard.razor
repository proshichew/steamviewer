@using Steamviewer.Entities.SteamModels
@using System.Globalization

<div class="game-card">
    <!-- Кнопки управления -->
    <button class="close-btn" @onclick="CloseCard">×</button>
    <button class="notif-btn" @onclick="ToggleNotifications" title="Уведомления">
        <img src="images/bell.png" alt="Уведомления" class="bell-icon @(NotificationsEnabled ? "enabled" : "disabled")" />
    </button>

    <!-- Левая часть: картинка и теги -->
    <div class="game-card-left">
        <img src="@Game.TinyImage" alt="@Game.Name"
             class="game-card-image"
             onerror="this.src='https://via.placeholder.com/300x150?text=No+Image'" />

        @if (Game.Tags != null && Game.Tags.Any())
        {
            <div class="game-card-tags">
                @foreach (var tag in Game.Tags.Take(5))
                {
                    <span class="game-tag">@tag</span>
                }
            </div>
        }
        <!-- Поле заметки -->
        <textarea class="note-box"
                  @bind="UserNote"
                  @bind:event="oninput"
                  placeholder="Введите заметку...">
        </textarea>
    </div>

    <!-- Правая часть: инфа об игре -->
    <div class="game-card-right">
        <div>
            <div class="game-card-title">@Game.Name</div>

            <div class="game-card-description">
                @(string.IsNullOrWhiteSpace(Game.Description)
                    ? "Описание недоступно."
                    : Game.Description)
            </div>

            @if (Game.ReleaseDate.HasValue)
            {
                <div class="game-card-meta">
                    <span class="game-card-meta-label">Дата выхода:</span>
                    <span class="game-card-meta-value">@Game.ReleaseDate.Value.ToString("dd MMM yyyy г.", new CultureInfo("ru-RU"))</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Game.Developer))
            {
                <div class="game-card-meta">
                    <span class="game-card-meta-label">Разработчик:</span>
                    <span class="game-card-meta-dev">@Game.Developer</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Game.Publisher))
            {
                <div class="game-card-meta">
                    <span class="game-card-meta-label">Издатель:</span>
                    <span class="game-card-meta-pub">@Game.Publisher</span>
                </div>
            }
        </div>
        <div class="purchase-block">
            <div class="price-part">
                @if (Game.Price == null || Game.Price.Final == 0)
                {
                    <div class="discount-free">Бесплатно</div>
                }
                else
                {
                    <div class="discount-and-price">
                        <div class="discount-box">-@Game.Price.DiscountPercent%</div>

                        @if (Game.Price.DiscountPercent > 0)
                        {
                            <div class="old-price">@($"{Game.Price.Initial:F2} ₽")</div>
                        }

                        <div class="price-box">@($"{Game.Price.Initial:F2} ₽")</div>
                    </div>
                  
                }

                <button class="wishlist-button @(IsInWishlist ? "remove" : "add")" @onclick="ToggleWishlist">
                    @(IsInWishlist ? "Удалить" : "Добавить")
                </button>
            </div>
        </div>
        @if (ShowNotification)
        {
            <div class="toast">@NotificationMessage</div>
        }
    </div>
    <!-- Скидка, цена и кнопка -->
    

</div>

@code {
    [Parameter] public GameItem Game { get; set; } = default!;
    [Parameter] public EventCallback OnCardClose { get; set; }

    private bool NotificationsEnabled { get; set; } = false;
    private bool IsInWishlist { get; set; } = false;
    private string UserNote { get; set; } = string.Empty;

    private bool ShowNotification { get; set; } = false;
    private string NotificationMessage { get; set; } = string.Empty;

    private async Task CloseCard() => await OnCardClose.InvokeAsync();

    private void ToggleNotifications()
    {
        NotificationsEnabled = !NotificationsEnabled;
        ShowToast(NotificationsEnabled ? "Уведомления включены" : "Уведомления отключены");
    }

    private void ToggleWishlist()
    {
        IsInWishlist = !IsInWishlist;
        ShowToast(IsInWishlist ? "Добавлено в вишлист" : "Удалено из вишлиста");
    }

    private void ShowToast(string message)
    {
        NotificationMessage = message;
        ShowNotification = true;
        StateHasChanged();

        _ = Task.Delay(2000).ContinueWith(_ =>
        {
            ShowNotification = false;
            InvokeAsync(StateHasChanged);
        });
    }
}

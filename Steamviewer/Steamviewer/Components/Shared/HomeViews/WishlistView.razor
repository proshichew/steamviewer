@inject AppStateService AppState
@inject Steamviewer.Services.Interfaces.IWishlistService WishlistService
@inject SteamService SteamService

<div class="games-container">
    @if (selectedGames.Count == 0) //пока не используется
    {
        <p class="empty-message">No games in your wishlist</p>
    }
    else
    {
        @foreach (var game in selectedGames)
        {
            <GameCard Game="game" OnCardClose="@(() => RemoveSelectedGame(game))" />
        }
    }
</div>

@code {
    private Dictionary<int, List<GameCardInfo>> cachedWishlistGames = new();
    private List<GameCardInfo> selectedGames = new();

    protected override async Task OnInitializedAsync()
    {
        AppState.OnSelectedWishlistChanged += HandleWishlistChanged;
        await LoadSelectedWishlistGames();
    }

    // Перенести сюда методы из Home.razor:
    // HandleWishlistChanged, LoadSelectedWishlistGames, 
    // RemoveSelectedGame, Dispose

    private async void HandleWishlistChanged(int? wishlistId)
    {
        await LoadSelectedWishlistGames();
        StateHasChanged();
    }

    private async Task LoadSelectedWishlistGames()
    {
        if (AppState.SelectedWishlistId.HasValue)
        {
            if (!cachedWishlistGames.TryGetValue(AppState.SelectedWishlistId.Value, out selectedGames))
            {
                var gameIds = await WishlistService.GetWishlistGamesAsync(AppState.SelectedWishlistId.Value);
                var loadedGames = new List<GameCardInfo>();

                foreach (var gameDto in gameIds)
                {
                    AppDetails gameItem = await SteamService.GetAppDataAsync(gameDto.SteamId);
                    loadedGames.Add(new GameCardInfo(gameItem, gameDto));
                }

                selectedGames = loadedGames;
                cachedWishlistGames[AppState.SelectedWishlistId.Value] = selectedGames;
            }
        }
        else
        {
            selectedGames.Clear();
        }
    }

    public void Dispose()
    {
        AppState.OnSelectedWishlistChanged -= HandleWishlistChanged;
    }

    private async void HandleGameAdded(GameItem game)
    {
        if (!selectedGames.Any(g => g.SteamId == game.Id) && AppState.SelectedWishlistId.HasValue)
        {
            var gameData = await SteamService.GetAppDataAsync(game.Id);
            try
            {
                GameDTO dTO = new GameDTO(game.Id, game.Id, "Введите собственную заметку об игре", 20);
                await WishlistService.AddGameToWishlistAsync(
                    AppState.SelectedWishlistId.Value,
                    dTO);

                if (cachedWishlistGames.TryGetValue(AppState.SelectedWishlistId.Value, out var games))
                {
                    games.Add(new GameCardInfo(gameData, dTO));
                }
                else
                {
                    cachedWishlistGames[AppState.SelectedWishlistId.Value] = new List<GameCardInfo>
                    {
                        new GameCardInfo(gameData, dTO)
                    };
                }

                selectedGames = cachedWishlistGames[AppState.SelectedWishlistId.Value];
            }
            catch (ArgumentException ex)
            {
                // Handle exception
            }
            StateHasChanged();
        }
    }

    private async void RemoveSelectedGame(GameCardInfo game)
    {
        if (AppState.SelectedWishlistId.HasValue &&
            cachedWishlistGames.TryGetValue(AppState.SelectedWishlistId.Value, out var games))
        {
            games.Remove(game);
            await WishlistService.RemoveGameFromWishlistAsync(
                AppState.SelectedWishlistId.Value,
                game.DbId);

            selectedGames = games;
            StateHasChanged();
        }
    }

} *@
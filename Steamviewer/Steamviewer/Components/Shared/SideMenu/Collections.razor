@using Steamviewer.Entities;
@using Steamviewer.Entities.DTOs
@using Steamviewer.Services;
@using Steamviewer.Services.Interfaces;

@inject AppStateService AppState

<div>
    <div class="button-container">
        <input type="radio" id="collections" name="steamToggle" checked="@isFirstActive" @onchange="() => ToggleButton(true)" />
        <label for="collections" class="steam-button">Collections</label>

        <input type="radio" id="inventory" name="steamToggle" checked="@isSecondActive" @onchange="() => ToggleButton(false)" />
        <label for="inventory" class="steam-button">Inventory</label>
    </div>

    @if (isFirstActive)
    {
        <div class="wishlist-content">
            @if (wishlists == null)
            {
                <p class="loading-message">Loading wishlists...</p>
            }
            else
            {
                <div class="wishlist-sidebar">
                    <div class="wishlist-header">
                        <h3>Your Wishlists</h3>
                        <button class="add-wishlist-btn" @onclick="StartAddingWishlist" title="Add new wishlist">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                            </svg>
                        </button>
                    </div>

                    @if (isAddingWishlist)
                    {
                        <div class="wishlist-edit-form">
                            <input @bind="newWishlistName" class="wishlist-input" placeholder="Wishlist name" />
                            <textarea @bind="newWishlistDescription" class="wishlist-textarea" placeholder="Description (optional)"></textarea>
                            <div class="wishlist-form-buttons">
                                <button @onclick="CancelAddWishlist" class="wishlist-cancel-btn">Cancel</button>
                                <button @onclick="AddWishlist" class="wishlist-save-btn">Save</button>
                            </div>
                        </div>
                    }

                    <ul class="wishlist-list">
                        @foreach (var wishlist in wishlists)
                        {
                            <li class="wishlist-item @(AppState.CurrentSelection == SelectionType.Wishlist && AppState.SelectedId == wishlist.Id ? "selected" : "")"
                                @onclick="() => SelectWishlist(wishlist.Id)">
                                <div class="list-item-flex">
                                    <div>
                                        <div class="wishlist-name">@wishlist.Name</div>
                                        @if (!string.IsNullOrWhiteSpace(wishlist.UserDescription))
                                        {
                                            <div class="wishlist-description">@wishlist.UserDescription</div>
                                        }
                                    </div>
                                    <button class="delete-btn" @onclick:stopPropagation="true" @onclick="() => DeleteWishlist(wishlist.Id)" title="Delete wishlist">
                                        🗑️
                                    </button>
                                </div>
                            </li>
                        }
                    </ul>
                </div>

                @if (AppState.CurrentSelection == SelectionType.Wishlist && AppState.SelectedId.HasValue)
                {
                    <div class="wishlist-games">
                        <h3>Games in this wishlist</h3>
                        @if (wishlistGames == null)
                        {
                            <p class="loading-message">Loading games...</p>
                        }
                        else if (!wishlistGames.Any())
                        {
                            <p class="empty-message">No games in this wishlist</p>
                        }
                        else
                        {
                            <div class="games-grid">
                                @foreach (var game in wishlistGames)
                                {
                                    <div class="game-card">
                                        <h4 class="game-title">Game #@game.SteamId</h4>
                                        @if (!string.IsNullOrWhiteSpace(game.UserNote))
                                        {
                                            <p class="game-note">@game.UserNote</p>
                                        }
                                        <div class="game-notification">
                                            Sale notification: @(game.SaleToNotify > 0 ? $"{game.SaleToNotify}%" : "Off")
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    }
    @if (isSecondActive)
    {
        <div class="inventory-content">
            <div class="inventory-header">
                <h3>Your Inventories</h3>
                <button class="add-inventory-btn" @onclick="StartAddingInventory" title="Add new inventory">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                </button>
            </div>
        </div>

        @if (isAddingInventory)
        {
            <div class="inventory-creation-form">
                <input @bind="newInventoryPlayerId" class="inventory-input" placeholder="Enter Player ID" />
                @if (!string.IsNullOrEmpty(inventoryError))
                {
                    <div class="inventory-error-message">@inventoryError</div>
                }
                <div class="inventory-form-buttons">
                    <button @onclick="CancelAddInventory" class="inventory-cancel-btn">Cancel</button>
                    <button @onclick="AddInventory" class="inventory-save-btn">Save</button>
                </div>
            </div>
        }
        @if (inventories == null)
        {
            <p class="loading-message">Loading inventories...</p>
        }
        else if (!inventories.Any())
        {
            <p class="empty-message">No inventories found.</p>
        }
        else
        {
            <ul class="inventory-list">
                @foreach (var inventory in inventories)
                {
                    <li class="inventory-item @(AppState.CurrentSelection == SelectionType.Inventory && AppState.SelectedId == inventory.Id ? "selected" : "")"
                        @onclick="() => SelectInventory(inventory.Id)">
                        <div class="list-item-flex">
                            <div>
                                <div class="inventory-name">@inventory.Name</div>
                                <div class="inventory-playerid">Player ID: @inventory.PlayerId</div>
                                <div class="inventory-game">Game: @inventory.GameName</div>
                                <div class="inventory-items-count">Items: @(inventory.Items?.Count ?? 0)</div>
                            </div>
                            <button class="delete-btn" @onclick:stopPropagation="true" @onclick="() => DeleteInventory(inventory.Id)" title="Delete inventory">
                                🗑️
                            </button>
                        </div>
                    </li>
                }
            </ul>
        }
    }
</div>

@code {
    private bool isFirstActive = true;
    private bool isSecondActive = false;
    private IEnumerable<WishlistDto>? wishlists;
    private IEnumerable<GameDTO>? wishlistGames;
    private bool isAddingWishlist = false;
    private string newWishlistName = string.Empty;
    private string newWishlistDescription = string.Empty;
    private bool isAddingInventory = false;
    private string newInventoryPlayerId = string.Empty;
    private string inventoryError = string.Empty;
    private InventoryDto? currentInventory;
    private IEnumerable<InventoryDto>? inventories;

    [Inject]
    private IWishlistService WishlistService { get; set; } = null!;
    [Inject]
    private IInventoryService InventoryService { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await LoadWishlists();
        if (isSecondActive)
        {
            await LoadInventories();
        }
    }

    private async Task LoadWishlists()
    {
        wishlists = await WishlistService.GetAllAsync();
    }

    private async Task SelectWishlist(int wishlistId)
    {
        AppState.SelectWishlist(wishlistId);
        wishlistGames = await WishlistService.GetWishlistGamesAsync(wishlistId);
    }

    private async Task ToggleButton(bool selectFirst)
    {
        isFirstActive = selectFirst;
        isSecondActive = !selectFirst;
        if (isSecondActive)
        {
            await LoadInventories();
            StateHasChanged();
        }
    }

    private void StartAddingWishlist()
    {
        isAddingWishlist = true;
        newWishlistName = string.Empty;
        newWishlistDescription = string.Empty;
    }

    private void CancelAddWishlist()
    {
        isAddingWishlist = false;
    }

    private async Task AddWishlist()
    {
        if (string.IsNullOrWhiteSpace(newWishlistName))
        {
            return;
        }

        var newWishlist = new WishlistDto(0, newWishlistName, newWishlistDescription);
        await WishlistService.AddWishlistAsync(newWishlist);
        await LoadWishlists();
        isAddingWishlist = false;
    }

    // INVENTORY
    private void StartAddingInventory()
    {
        isAddingInventory = true;
        newInventoryPlayerId = string.Empty;
    }
    private void CancelAddInventory()
    {
        isAddingInventory = false;
    }
    private async Task AddInventory()
    {
        inventoryError = string.Empty;
        if (string.IsNullOrWhiteSpace(newInventoryPlayerId))
        {
            inventoryError = "Player ID cannot be empty.";
            StateHasChanged();
            return;
        }

        // Проверка на существующий Player ID в локальном списке
        if (inventories != null && inventories.Any(inv => inv.PlayerId == newInventoryPlayerId))
        {
            inventoryError = "Inventory with this Player ID already exists.";
            StateHasChanged();
            return;
        }

        // var existing = await InventoryService.GetByPlayerIdAsync(newInventoryPlayerId);
        // if(existing != null)
        // {
        //     currentInventory = existing;
        //     inventoryError = "Inventory already exists. Loaded existing.";
        //     isAddingInventory = false;
        //     StateHasChanged();
        //     return;
        // }

        var created = await InventoryService.AddInventoryAsync(newInventoryPlayerId);
        if (created != null)
        {
            currentInventory = created;
            isAddingInventory = false;
            await LoadInventories();
        }
        else
        {
            inventoryError = "Failed to create inventory.";
        }
        StateHasChanged();
    }

    private async Task LoadInventories()
    {
        inventories = await InventoryService.GetAllAsync();
    }

    private void SelectInventory(int inventoryId)
    {
        AppState.SelectInventory(inventoryId);
    }

    private async Task DeleteWishlist(int id)
    {
        await WishlistService.DeleteWishlistAsync(id);
        await LoadWishlists();
        if (AppState.SelectedId == id && AppState.CurrentSelection == SelectionType.Wishlist)
        {
            AppState.ClearSelection();
            wishlistGames = null;
        }
        StateHasChanged();
    }

    private async Task DeleteInventory(int id)
    {
        await InventoryService.DeleteAsync(id);
        await LoadInventories();
        if (AppState.SelectedId == id && AppState.CurrentSelection == SelectionType.Inventory)
        {
            AppState.ClearSelection();
        }
        StateHasChanged();
    }
}
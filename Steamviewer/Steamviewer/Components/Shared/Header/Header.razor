@using Steamviewer.Components.Shared.Services
@using Steamviewer.Entities.SteamModels
@inject SteamService SteamService
@using Microsoft.AspNetCore.Components.Web

<div class="search-container">
    <!-- Строка поиска -->
    <div class="search-header">
        <div class="search-box @(searchResults?.Items?.Any() == true ? "active" : "")">
            <input type="text"
                   placeholder="Поиск игр..."
                   @bind="searchText"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown" />
            <button @onclick="SearchGames" disabled="@isSearching">
                <img src="images/Search.png" alt="Поиск" class="search-icon" />
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="search-error-message">@errorMessage</div>
    }


    <!-- Выпадающий список поиска -->
    @if (!string.IsNullOrWhiteSpace(searchText) && searchResults?.Items?.Any() == true)
    {
        <div class="search-dropdown">
            @foreach (var game in searchResults.Items)
            {
                <!-- один элемент списка - игра -->
                <div class="search-result-item">
                    <img src="@game.TinyImage" alt="@game.Name" class="game-image"
                         onerror="this.src='https://via.placeholder.com/50x50?text=No+Image'" />
                    <div class="game-name">@game.Name</div>
                    <div class="game-price">
                        @if (game.Price != null)
                        {
                            @if (game.Price.DiscountPercent > 0)
                            {
                                <span class="old-price">
                                    @(game.Price.Initial.HasValue ? $"${game.Price.Initial.Value:0.00}" : "")
                                </span>
                                <span class="final-price @(game.Price.Final == 0 ? "free" : "")">
                                    @(game.Price.Final == 0 ? "Бесплатно" : $"${game.Price.Final:0.00}")
                                </span>
                            }
                            else
                            {
                                <span class="final-price @(game.Price.Final == 0 ? "free" : "")">
                                    @(game.Price.Final == 0 ? "Бесплатно" : $"${game.Price.Final:0.00}")
                                </span>
                            }
                        }
                        else
                        {
                            <span class="final-price free">Бесплатно</span>
                        }
                    </div>

                    <button @onclick="() => AddToCollection(game)" class="add-button">+</button>
                </div>
            }
        </div>
    }
</div>

@code {
    private SteamSearchResult searchResults = new();
    private bool isSearching = false;
    private string? errorMessage;

    private string _searchText = string.Empty;

    private string searchText
    {
        get => _searchText;
        set
        {
            _searchText = value;

            if (string.IsNullOrWhiteSpace(_searchText))
            {
                searchResults = new SteamSearchResult();
                errorMessage = null;
            }
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchGames();
        }
    }

    private async Task SearchGames()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            errorMessage = "Введите название игры для поиска";
            return;
        }

        errorMessage = null;
        isSearching = true;
        StateHasChanged(); // Обновление UI вручную

        try
        {
            searchResults = await SteamService.SearchGamesAsync(searchText);

            if (searchResults == null || searchResults.Items.Count == 0)
            {
                errorMessage = "Ничего не найдено. Попробуйте изменить запрос.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Ошибка при поиске игр. Пожалуйста, попробуйте позже.";
            Console.WriteLine($"Ошибка поиска: {ex.Message}");
            searchResults = new SteamSearchResult();
        }
        finally
        {
            isSearching = false;
        }
    }

    private void AddToCollection(GameItem game)
    {
        // Логика добавления игры в коллекцию
        Console.WriteLine($"Добавлена игра: {game.Name} (ID: {game.Id})");
    }
}


    private async void HandleSelectionChanged(SelectionType type, int? id)
    {
        if (type == SelectionType.Wishlist && id.HasValue)
        {
            await LoadSelectedWishlistGames(id.Value);
            selectedInventoryItems = null;
        }
        else if (type == SelectionType.Inventory && id.HasValue)
        {
            await LoadSelectedInventoryItems(id.Value);
            selectedGames = new List<GameCardInfo>();
        }
        else if (type == SelectionType.Top100)
        {
            Top100Games = (await SteamService.GetTop100Games()).ToList();
            showTop100 = true;
            selectedGames = new List<GameCardInfo>();
            //Games.Clear();
            selectedInventoryItems = null;
        }
        else
        {
            selectedGames = new List<GameCardInfo>();
            selectedInventoryItems = null;
        }
        StateHasChanged();
    }

    private async Task LoadSelectedWishlistGames(int wishlistId)
    {
        if (!cachedWishlistGames.TryGetValue(wishlistId, out selectedGames))
        {
            var gameIds = await WishlistService.GetWishlistGamesAsync(wishlistId);
            var loadedGames = new List<GameCardInfo>();

            foreach (var gameDto in gameIds)
            {
                AppDetails gameItem = await SteamService.GetAppDataAsync(gameDto.SteamId);
                loadedGames.Add(new GameCardInfo(gameItem, gameDto));
            }

            selectedGames = loadedGames;
            cachedWishlistGames[wishlistId] = loadedGames;
        }
        UpdateWishlistTotal();
    }

    private void UpdateWishlistTotal()
    {
        decimal total = 0;
        foreach (var g in selectedGames)
        {
            if (!string.IsNullOrWhiteSpace(g.FinalPriceFormatted))
            {
                // Все нецифровые символы кроме запятой и точки
                var priceStr = new string(g.FinalPriceFormatted
                    .TakeWhile(c => char.IsDigit(c) || c == ',' || c == '.')
                    .ToArray());

                priceStr = priceStr.Replace(',', '.');

                if (decimal.TryParse(priceStr, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var price))
                {
                    total += price;
                }
            }
        }
        AppState.SetSelectedWishlistTotal(total);
    }

    private async Task LoadSelectedInventoryItems(int inventoryId)
    {
        selectedInventoryItems = await InventoryService.GetInventoryItemsAsync(inventoryId);
    }


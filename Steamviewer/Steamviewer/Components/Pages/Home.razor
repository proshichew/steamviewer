    private async void HandleGameAdded(GameItem game)
    {
        if (!selectedGames.Any(g => g.SteamId == game.Id) && AppState.CurrentSelection == SelectionType.Wishlist && AppState.SelectedId.HasValue)
        {
            var gameData = await SteamService.GetAppDataAsync(game.Id);
            try
            {
                GameDTO dTO = new GameDTO(game.Id, game.Id, "Введите собственную заметку об игре", 20);
                await WishlistService.AddGameToWishlistAsync(
                    AppState.SelectedId.Value,
                    dTO);

                if (cachedWishlistGames.TryGetValue(AppState.SelectedId.Value, out var games))
                {
                    games.Add(new GameCardInfo(gameData, dTO));
                }
                else
                {
                    cachedWishlistGames[AppState.SelectedId.Value] = new List<GameCardInfo>
                    {
                        new GameCardInfo(gameData, dTO)
                    };
                }

                selectedGames = cachedWishlistGames[AppState.SelectedId.Value];
            }
            catch (ArgumentException ex)
            {
                
            }
            UpdateWishlistTotal();
            StateHasChanged();
        }
    }


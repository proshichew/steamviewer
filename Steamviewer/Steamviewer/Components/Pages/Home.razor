    private async void RemoveSelectedGame(GameCardInfo game)
    {
        if (AppState.CurrentSelection == SelectionType.Wishlist && AppState.SelectedId.HasValue &&
            cachedWishlistGames.TryGetValue(AppState.SelectedId.Value, out var games))
        {
            games.Remove(game);
            await WishlistService.RemoveGameFromWishlistAsync(
                AppState.SelectedId.Value,
                game.DbId);

            selectedGames = games;
            UpdateWishlistTotal();
            StateHasChanged();
        }
    }

    private void RemoveGame(GameCardInfo game)
    {
        Games.Remove(game);
        StateHasChanged();

<PageTitle>Steam</PageTitle>

<Header OnGameAdded="HandleGameAdded"/>

<div class="games-container">
    @if (AppState.CurrentSelection == SelectionType.Wishlist && AppState.SelectedId.HasValue)
    {
        @foreach (var game in selectedGames)
        {
            <GameCard Game="game" OnCardClose="@(() => RemoveSelectedGame(game))" />
        }

        @foreach (var game in Games)
        {
            <GameCard Game="game" OnCardClose="@(() => RemoveGame(game))" />
        }
    }

    else if (AppState.CurrentSelection == SelectionType.Inventory && AppState.SelectedId.HasValue && selectedInventoryItems != null)
    {
        <div class="items-container">
            @foreach (var item in selectedInventoryItems)
            {
                <ItemCard Item="item" />
            }
        </div>
    }
    else if (showTop100 && Top100Games != null)
    {
        <div class="top100-list">
            @foreach (var game in Top100Games)
            {
                <TopChip Game="game" />
            }
        </div>

    }
</div>

